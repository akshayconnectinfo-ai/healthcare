graph LR
    Patient[Patient]
    Admin[Admin]
    
    P1((P1 Register))
    P2((P2 Appointments))
    P3((P3 Auth))
    P4((P4 Send SMS))
    P5((P5 Documents))

    D1[(D1 Users)]
    D2[(D2 Patients)]
    D3[(D3 Appointments)]
    D4[(D4 Documents)]

    Patient -- User Info ---> P1
    P1 -- Store User ---> D1
    P1 -- Patient Data ---> D2

    Patient -- Request Appt ---> P2
    P2 -- Create Status ---> D3
    
    Admin -- Schedule/Cancel ---> P2
    P2 -- Update Status ---> D3
    
    P2 -- Trigger ID ---> P4

    Admin -- Passkey Auth ---> P3
    P3 -- Grant Access ---> Admin

    P4 -- SMS Alert ---> Patient

    Patient -- Upload ID ---> P5
    P5 -- Save File ---> D4
